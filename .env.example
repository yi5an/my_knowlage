KNOWPILOT_ENV=development
KNOWPILOT_DEBUG=true
KNOWPILOT_LOG_LEVEL=INFO
KNOWPILOT_API_V1_PREFIX=/api/v1
KNOWPILOT_CORS_ORIGINS=http://localhost:5173

