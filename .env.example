KNOWPILOT_ENV=development
KNOWPILOT_DEBUG=true
KNOWPILOT_LOG_LEVEL=INFO
KNOWPILOT_API_V1_PREFIX=/api/v1
KNOWPILOT_CORS_ORIGINS=http://localhost:5173

POSTGRES_DB=knowpilot
POSTGRES_USER=knowpilot
POSTGRES_PASSWORD=knowpilot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+psycopg://knowpilot:knowpilot@postgres:5432/knowpilot
LOCAL_STORAGE_DIR=./backend/storage

# LLM (OpenAI-compatible). Required for real research/summary/extraction.
# Leave unset to run with a mock LLM (offline / tests).
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=
LLM_MAX_OUTPUT_TOKENS=2048

# Web search provider for the deep-research agent (Tavily).
# Get a key at https://tavily.com. Leave unset to use a mock search client
# locally; production research tasks require a real key.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_MAX_RESULTS=5
